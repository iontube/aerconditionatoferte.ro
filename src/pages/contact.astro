---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Contact — AerConditionatOferte.ro" description="Trimite-ne un mesaj pentru intrebari despre oferte aer conditionat, colaborari sau corectii.">
  <div data-contact>
    <h1>Contact</h1>
    <div data-contact-card>
      <div data-contact-icon><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M22 4L12 13 2 4"/></svg></div>
      <p>Pentru intrebari, sugestii sau colaborari:</p>
      <a href="mailto:contact@aerconditionatoferte.ro" data-contact-email>contact@aerconditionatoferte.ro</a>
      <p style="color:var(--c-muted);margin-top:10px;font-size:.88rem">Raspundem in 24-48 de ore.</p>
    </div>
  </div>
</Layout>
